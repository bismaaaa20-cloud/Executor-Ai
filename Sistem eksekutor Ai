getfenv().hookfunction = function(old_func, new_func) old_func = new_func return old_func end
getfenv().firetouchinterest = function(part1, part2, toggle)
	if part1 and part2 then pcall(function() firetouchinterest(part1, part2, toggle) end) end
end
getfenv().fireclickdetector = function(clickDetector, distance)
	if clickDetector then pcall(function() fireclickdetector(clickDetector, distance or 0) end) end
end
getfenv().writefile = function(filename, content) _virtual_files[filename] = tostring(content) end
getfenv().readfile = function(filename)
	if _virtual_files[filename] then return _virtual_files[filename] else error("File tidak ditemukan") end
end

-- 💬 Fungsi Pembantu Status Obrolan AI
local function updateAiChat(message) aiChatLog.Text = "[AI Assistant]: " .. message end

-- ====================================================================
-- 🔎 SCANNER INTERNAL GAME (Gaya Dark Dex)
-- ====================================================================
local function scanGameStructure()
	local structureData = { GameName = game.Name, Objects = {} }
	local function readChildren(parentObj, currentTable, maxDepth)
		if maxDepth <= 0 then return end
		for _, child in pairs(parentObj:GetChildren()) do
			if not child:IsA("CoreScript") and not child:IsA("PlayerGui") then
				local itemData = { Name = child.Name, ClassName = child.ClassName, Children = {} }
				if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then itemData.FullName = child:GetFullName() end
				table.insert(currentTable, itemData)
				pcall(function() readChildren(child, itemData.Children, maxDepth - 1) end)
			end
		end
	end
	pcall(function() readChildren(Workspace, structureData.Objects, 2) end)
	pcall(function() readChildren(ReplicatedStorage, structureData.Objects, 2) end)
	return HttpService:JSONEncode(structureData)
end

local runExecutorEngine

-- ====================================================================
-- SECTION 1: CORE AI ENGINE (KONEKSI INTERNET GEMINI & OPENAI)
-- ====================================================================

local function generateOrConvertViaGemini(inputText, gameFileStructure)
	local url = "https://googleapis.com" .. GEMINI_API_KEY
	local promptInstruction = "Kamu adalah mesin AI Executor bernama " .. EXECUTOR_NAME .. " yang terhubung ke internet untuk belajar membuat skrip 100% lebih bagus. "
		.. "Tugasmu: Ubah skrip asal (Python, JS, dll) atau buatkan skrip baru berdasarkan perintah teks pengguna. "
		.. "ATURAN UTAMA: Jika pengguna meminta skrip untuk GAME INI, baca Struktur File JSON Game yang disediakan di bawah untuk mencari nama RemoteEvent/objek asli agar skrip pas tanpa salah tebak! "
		.. "Jika ada menu UI, buat versi UI Roblox-nya menggunakan UDim2 SCALE agar pas di HP. JANGAN banyak tanya, JANGAN berikan teks penjelasan. Berikan HANYA kode Lua bersih tanpa markdown triple backticks."

	local requestBody = { contents = { { parts = { { text = promptInstruction .. "\n\n[STRUKTUR FILE GAME]:\n" .. gameFileStructure .. "\n\n[PERINTAH/SKRIP ASAL]:\n" .. inputText } } } } }
	local success, response = pcall(function() return HttpService:PostAsync(url, HttpService:JSONEncode(requestBody), Enum.HttpContentType.ApplicationJson) end)
	if success then
		local data = HttpService:JSONDecode(response)
		if data.candidates and data.candidates.content.parts then
			local cleanLua = data.candidates.content.parts.text
			cleanLua = string.gsub(cleanLua, "```lua", ""):gsub("```", "")
			return cleanLua:match("^%s*(.-)%s*$")
		end
	end
	return nil
end

local function debugScriptViaOpenAI(currentText, errorMsg)
	local url = "https://openai.com"
	local headers = { ["Authorization"] = "Bearer " .. OPENAI_API_KEY, ["Content-Type"] = "application/json" }
	local requestBody = {
		model = "gpt-4o-mini", response_format = { type = "json_object" },
		messages = {
			{ role = "system", content = "Kamu adalah robot auto-debugging internal internet untuk " .. EXECUTOR_NAME .. ". Analisis error log, cari baris nomor berapa yang rusak, jelaskan singkat, lalu cari solusi terbaik di internet dan berikan kode yang sudah diperbaiki 100% bagus. Respon HARUS JSON: {\"line\": nomor_baris, \"reason\": \"alasan\", \"fixedScript\": \"kode_perbaikan\"}" },
			{ role = "user", content = "Skrip:\n" .. currentText .. "\n\nError:\n" .. errorMsg }
		}
	}
	local success, response = pcall(function() return HttpService:PostAsync(url, HttpService:JSONEncode(requestBody), Enum.HttpContentType.ApplicationJson, false, headers) end)
	if success then
		local data = HttpService:JSONDecode(response)
		if data.choices and data.choices.message then return HttpService:JSONDecode(data.choices.message.content) end
	end
	return nil
end

-- ====================================================================
-- SECTION 2: EXECUTOR AUTOMATION LOGIC (WITH AUTO-RETRY)
-- ====================================================================

runExecutorEngine = function()
	if scriptEditor.Text == "" then return end
	updateAiChat("Mengeksekusi skrip...")
	
	local errorConnection
	errorConnection = LogService.MessageOut:Connect(function(message, messageType)
		if messageType == Enum.MessageType.MessageOutputError then
			errorConnection:Disconnect()
			updateAiChat("Mendeteksi error! AI sedang belajar membetulkan kode...")
			
			task.spawn(function()
				local debugResult = debugScriptViaOpenAI(scriptEditor.Text, message)
				if debugResult then
					updateAiChat("ERROR di Baris " .. tostring(debugResult.line) .. " -> " .. debugResult.reason .. ". Mencoba Ulang...")
					scriptEditor.Text = debugResult.fixedScript
					task.wait(1)
					runExecutorEngine() 
				end
			end)
		end
	end)
	
	local success, err = pcall(function()
		local executableFunc = loadstring(scriptEditor.Text)
		if executableFunc then
			local env = getfenv(executableFunc)
			env.getgenv = getfenv().getgenv
			env.identifyexecutor = getfenv().identifyexecutor
			env.getexecutorname = getfenv().getexecutorname
			env.setclipboard = getfenv().setclipboard
			env.toclipboard = getfenv().toclipboard
			env.hookfunction = getfenv().hookfunction
			env.firetouchinterest = getfenv().firetouchinterest
			env.fireclickdetector = getfenv().fireclickdetector
			env.writefile = getfenv().writefile
			env.readfile = getfenv().readfile
			env.owner = Players.LocalPlayer
			setfenv(executableFunc, env)
			executableFunc()
		else
			error("Syntax Error")
		end
	end)
	
	if success then
		task.wait(1)
		if errorConnection.Connected then
			errorConnection:Disconnect()
			updateAiChat("Skrip sukses berjalan 100% lancar!")
		end
	end
end

