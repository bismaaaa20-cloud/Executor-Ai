-- BAGIAN 5: UI INTERACTION & AUTOMATIC EXECUTION LOGIC
-- ====================================================================
local runExecutorEngine
runExecutorEngine = function()
	if scriptEditor.Text == "" then return end
	updateAiChat("Mengeksekusi skrip...")
	
	task.spawn(function()
		local errorConnection
		errorConnection = LogService.MessageOut:Connect(function(message, messageType)
			if messageType == Enum.MessageType.MessageOutputError then
				errorConnection:Disconnect()
				updateAiChat("Mendeteksi error! AI sedang membetulkan kode...")
				
				task.spawn(function()
					local debugResult = debugScriptViaOpenAI(scriptEditor.Text, message)
					if debugResult then
						updateAiChat("ERROR di Baris " .. tostring(debugResult.line) .. " -> " .. debugResult.reason .. ". Mencoba Ulang...")
						scriptEditor.Text = debugResult.fixedScript
						task.wait(1)
						runExecutorEngine() -- 🔄 Auto-retry otomatis jalankan ulang kodenya
					end
				end)
			end
		end)
		
		-- Eksekusi Aman Anti-Freeze Menggunakan Isolasi Thread task.spawn
		pcall(function()
			local executableFunc = loadstring(scriptEditor.Text)
			if executableFunc then
				local env = getfenv(executableFunc)
				env.getgenv = _custom_global_env.getgenv
				env.identifyexecutor = _custom_global_env.identifyexecutor
				env.getexecutorname = _custom_global_env.getexecutorname
				env.setclipboard = _custom_global_env.setclipboard
				env.toclipboard = _custom_global_env.toclipboard
				env.hookfunction = _custom_global_env.hookfunction
				env.firetouchinterest = _custom_global_env.firetouchinterest
				env.fireclickdetector = _custom_global_env.fireclickdetector
				env.writefile = _custom_global_env.writefile
				env.readfile = _custom_global_env.readfile
				env.HttpGet = _custom_global_env.HttpGet
				env.owner = Players.LocalPlayer
				setfenv(executableFunc, env)
				
				task.spawn(executableFunc) -- Dijalankan di alur terpisah agar UI tidak hang
			else
				error("Syntax Error")
			end
		end)
	end)
end

-- Trigger 1: Selesai Mengetik di Editor (Konversi Otomatis)
scriptEditor.FocusLost:Connect(function(enterPressed)
	if scriptEditor.Text == "" or scriptEditor.Text == " " then return end
