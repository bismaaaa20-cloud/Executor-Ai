scriptEditor.FocusLost:Connect(function(enterPressed)
	if scriptEditor.Text == "" or scriptEditor.Text == " " then return end
	
	local gameJsonStructure = scanGameStructure()
	updateAiChat("AI sedang menganalisis file game & memproses skrip...")
	
	task.spawn(function()
		local finalLua = generateOrConvertViaGemini(scriptEditor.Text, gameJsonStructure)
		if finalLua then
			scriptEditor.Text = finalLua
			updateAiChat("Proses selesai! Skrip dioptimalkan untuk perangkat Anda.")
		end
	end)
end)

executeBtn.MouseButton1Click:Connect(function() runExecutorEngine() end)

