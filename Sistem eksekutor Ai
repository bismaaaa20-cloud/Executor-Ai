local EXECUTOR_NAME = "SupremeAI_Executor"
local EXECUTOR_VERSION = "v5.5_ClearEdition"
local _virtual_files = {} 

getfenv().identifyexecutor = function() return EXECUTOR_NAME, EXECUTOR_VERSION end
getfenv().getexecutorname = function() return EXECUTOR_NAME end
getfenv().setclipboard = function(text) print("[Clipboard]: Teks disalin: " .. tostring(text)) end
