scriptEditor.FocusLost:Connect(function(enterPressed)
	if scriptEditor.Text == "" or scriptEditor.Text == " " then return end
	if string.find(scriptEditor.Text, "HttpGet") or string.find(scriptEditor.Text, "loadstring") then return end
	
	updateAiChat("AI Cloud sedang mengonversi & menciptakan file...")
	task.spawn(function()
		local gameJsonStructure = scanGameStructure()
		local finalLua = generateOrConvertViaGemini(scriptEditor.Text, gameJsonStructure)
		if finalLua then 
			scriptEditor.Text = finalLua 
			
			local detectedFileName = "AI_Generated_Script.lua"
			local lines = string.split(finalLua, "\n")
			if lines and string.find(lines, "FILE_NAME:") then
				detectedFileName = string.gsub(lines, "%-%-%s*FILE_NAME:%s*", ""):match("^%s*(.-)%s*$")
			end
			
			if writefile then
				writefile(detectedFileName, finalLua)
				updateAiChat("Sukses! File diciptakan: '" .. detectedFileName .. "'")
			else
				_custom_global_env.writefile(detectedFileName, finalLua)
				updateAiChat("Sukses! Disimpan ke memori virtual: '" .. detectedFileName .. "'")
			end
		end
	end)
end)

