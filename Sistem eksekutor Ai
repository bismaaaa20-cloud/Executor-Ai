-- BAGIAN 4: CORE AI CLOUD INTERFACES (AUTO-FILE DETECTOR ENABLED)
-- ====================================================================
local function customPostRequest(url, bodyData, headersData)
	if not requestFunc then return HttpService:PostAsync(url, bodyData, Enum.HttpContentType.ApplicationJson, false, headersData) end
	local response = requestFunc({Url = url, Method = "POST", Headers = headersData or {["Content-Type"] = "application/json"}, Body = bodyData})
	if response and response.Success then return response.Body else error("Internet Error") end
end

local function generateOrConvertViaGemini(inputText, gameFileStructure)
	local url = "https://googleapis.com" .. GEMINI_API_KEY
	local prompt = "Kamu adalah AI Cloud Generator. Ubah skrip asal menjadi skrip Lua Roblox siap pakai di PC/HP. "
		.. "Jika ada menu UI, buat versi UI Roblox SCALE. Berikan HANYA kode Lua bersih tanpa markdown backticks triple. "
		.. "ATURAN WAJIB: Buat baris paling atas kodenya berisi komentar nama file unduhan yang cocok untuk skrip itu (Contoh format: -- FILE_NAME: nama_skrip.lua)"
		
	local body = HttpService:JSONEncode({ contents = { { parts = { { text = prompt .. "\n\n[STRUKTUR GAME]:\n" .. gameFileStructure .. "\n\n[PERINTAH]:\n" .. inputText } } } } })
	local success, response = pcall(function() return customPostRequest(url, body) end)
	if success then
		local data = HttpService:JSONDecode(response)
		if data.candidates and data.candidates.content.parts then
			local clean = data.candidates.content.parts.text
			return string.gsub(clean, "```lua", ""):gsub("```", ""):match("^%s*(.-)%s*$")
		end
	end
	return nil
end

local function debugScriptViaOpenAI(currentText, errorMsg)
	local url = "https://openai.com"
	local headers = { ["Authorization"] = "Bearer " .. OPENAI_API_KEY, ["Content-Type"] = "application/json" }
	local body = HttpService:JSONEncode({
		model = "gpt-4o-mini", response_format = { type = "json_object" },
		messages = {
			{ role = "system", content = "Analisis error log, cari baris rusak, berikan kode perbaikan. Respon HARUS JSON: {\"line\": nomor_baris, \"reason\": \"alasan\", \"fixedScript\": \"kode_perbaikan\"}" },
			{ role = "user", content = "Skrip:\n" .. currentText .. "\n\nError:\n" .. errorMsg }
		}
	})
	local success, response = pcall(function() return customPostRequest(url, body, headers) end)
	if success then
		local data = HttpService:JSONDecode(response)
		if data.choices and data.choices.message then return HttpService:JSONDecode(data.choices.message.content) end
	end
	return nil
end
