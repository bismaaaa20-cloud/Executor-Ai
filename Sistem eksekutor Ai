-- Bypass Khusus game:HttpGet
_custom_global_env.HttpGet = function(self, url)
	local targetUrl = url or self
	local success, result = pcall(function() return HttpService:GetAsync(targetUrl) end)
	if success then return result else error("Gagal memuat URL") end
end
game.HttpGet = _custom_global_env.HttpGet

-- Scanner Struktur Internal Game (Dark Dex Engine)
local function scanGameStructure()
	local structureData = { GameName = game.Name, Objects = {} }
	local function readChildren(parentObj, currentTable)
		for _, child in pairs(parentObj:GetChildren()) do
			if not child:IsA("CoreScript") and not child:IsA("PlayerGui") then
				table.insert(currentTable, { Name = child.Name, ClassName = child.ClassName })
			end
		end
	end
	pcall(function() readChildren(Workspace, structureData.Objects) end)
	pcall(function() readChildren(ReplicatedStorage, structureData.Objects) end)
	return HttpService:JSONEncode(structureData)
end
