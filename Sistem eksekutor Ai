-- Scanner Struktur Internal Dokumen Game (Dark Dex Engine)
local function scanGameStructure()
	local structureData = { GameName = game.Name, Objects = {} }
	pcall(function()
		for _, child in pairs(Workspace:GetChildren()) do table.insert(structureData.Objects, { Name = child.Name, ClassName = child.ClassName }) end
		for _, child in pairs(ReplicatedStorage:GetChildren()) do table.insert(structureData.Objects, { Name = child.Name, ClassName = child.ClassName }) end
	end)
	return HttpService:JSONEncode(structureData)
end
